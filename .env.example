# Copy to .env and fill in. NEVER commit .env.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role key, Supabase dashboard → Settings → API>
DEEPSEEK_API_KEY=<platform.deepseek.com — keep the account PREPAID-ONLY>
APP_SHARED_SECRET=<random 32+ chars; same value goes into Edge Function secrets>
